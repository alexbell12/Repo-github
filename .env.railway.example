# Salin nilai ini ke Railway → Repo-github → Variables
# Hapus variabel duplikat MYSQL* jika sudah pakai "Connect MySQL" (opsional — kode sudah baca MYSQLHOST otomatis)

APP_NAME="Absensi Seminar"
APP_ENV=production
APP_KEY=base64:ISI_DARI_ENV_LOKAL
APP_DEBUG=false
APP_URL=https://repo-github-production-abf0.up.railway.app

# Cukup hubungkan service MySQL di Railway (Reference) — tidak wajib menulis DB_* manual
# Jika manual:
# DB_CONNECTION=mysql
# DB_HOST=mysql.railway.internal
# DB_PORT=3306
# DB_DATABASE=railway
# DB_USERNAME=root
# DB_PASSWORD=...

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
